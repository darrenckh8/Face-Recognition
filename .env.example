# Door Entry Kiosk - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# =============================================================================
# ADMIN PASSWORD HASH (REQUIRED)
# =============================================================================
# Generate a bcrypt hash for your admin password using:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'your_secure_password', bcrypt.gensalt(12)).decode())"
#
# Example (for password "admin123" - DO NOT USE IN PRODUCTION):
#   ADMIN_PASSWORD_HASH=$2b$12$LQv3c1yqBWVHxkd0LHAkCOYz6TtxMQJqhN8/X4.VTtYA/pPeBkJGy
#
ADMIN_PASSWORD_HASH=

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================
# You can override any Config class settings here as environment variables
# Examples:
#   RECOGNITION_THRESHOLD=0.85
#   COOLDOWN_SECONDS=10
